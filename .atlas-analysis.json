  "keyFeatures": [
    "Watches files and directories for changes using efficient kernel-level mechanisms (inotify, FSEvents, ReadDirectoryChangesW)",
    "Automatically runs commands on file changes with debouncing to coalesce multiple events",
    "Supports glob pattern filtering and ignore files (.gitignore, .ignore, etc.)",
    "Cross-platform: Linux, macOS, Windows, BSD",
    "Restarts long-running processes (servers, daemons) with configurable signals",
    "Emits structured event data (JSON or env vars) to child processes",
    "Interactive mode with keypress controls (restart, pause, quit)",
    "Desktop notifications on command start/end",
    "Rust library crate for building custom file-watching tools",
    "No language runtime dependency — single static binary"
  ],
  "publicApiSurface": [
    "watchexec [OPTIONS] [COMMAND]",
    "--watch / -w <PATH>",
    "--exts / -e <EXTENSIONS>",
    "--filter / -f <PATTERN>",
    "--ignore / -i <PATTERN>",
    "--restart / -r",
    "--on-busy-update / -o <MODE>",
    "--signal / -s <SIGNAL>",
    "--debounce / -d <TIMEOUT>",
    "--emit-events-to <MODE>",
    "--fs-events <EVENTS>",
    "--shell <SHELL>",
    "--clear / -c",
    "--notify / -N",
    "--interactive / -I",
    "--postpone / -p",
    "--filter-prog / -j <EXPRESSION>",
    "--poll [<INTERVAL>]",
    "--timings",
    "--wrap-process <MODE>",
    "Watchexec::new(action_handler) [Rust lib]",
    "Config::pathset() [Rust lib]",
    "Config::on_action() [Rust lib]",
    "Config::filterer() [Rust lib]",
    "ActionHandler::create_job() [Rust lib]",
    "ActionHandler::quit() / quit_gracefully() [Rust lib]"
  ]
